{
  "installCommand": "npm ci",
  "buildCommand": "npm run build:web",
  "outputDirectory": "dist/web",
  "framework": "vite",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'none'"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/downloads/(.*)",
      "headers": [
        {
          "key": "Content-Disposition",
          "value": "attachment"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/:path((?!assets/|downloads/|data/|api/|favicon\\.ico|favicon\\.png|favicon\\.svg|manifest\\.webmanifest|registerSW\\.js|sw\\.js|workbox-[^/]+\\.js|riot\\.txt).*)",
      "destination": "/index.html"
    }
  ]
}
