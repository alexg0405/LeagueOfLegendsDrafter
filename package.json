{
  "name": "league-drafter",
  "version": "3.11.0",
  "description": "Nexus//Draft — League of Legends draft helper with LCU, overlay, and heuristics",
  "author": "Nexus Draft contributors",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:web": "vite --config vite.web.config.ts",
    "build": "electron-vite build",
    "build:web": "vite build --config vite.web.config.ts",
    "preview": "electron-vite preview",
    "preview:web": "vite preview --config vite.web.config.ts --outDir dist/web",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b",
    "core:build": "wasm-pack build crates/nexus-draft-core --target web --release --out-dir ../../src/renderer/src/wasm/nexus-draft-core --out-name nexus_draft_core && node -e \"require('fs').rmSync('src/renderer/src/wasm/nexus-draft-core/.gitignore',{force:true})\"",
    "core:test": "cargo test -p nexus-draft-core",
    "core:check": "npm run core:test && npm run core:build && npm test -- --run src/shared/draft/itemMatrixRust.test.ts",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:win:signed": "npm run build && electron-builder --win --config electron-builder.signed.config.cjs",
    "dist:win:azcli": "npm run dist:win && npm run release:sign:azcli && npm run release:stage-web",
    "release:sign:azcli": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/sign-release-artifacts.ps1",
    "release:stage-web": "node scripts/stage-desktop-update-feed.mjs",
    "etl:riot-lane": "node scripts/riot-lane-etl.mjs",
    "items:update:ugg": "node scripts/update-ugg-default-builds.mjs",
    "meta:update:mobalytics": "node scripts/update-public-meta-mobalytics.mjs",
    "train:score": "python training/score_v1.py --state training/examples/live_state.example.json",
    "train:init-db": "python -m training.scripts.init_nexus_db",
    "etl:ingest": "python training/etl/ingest.py --db training/nexus_training.db --schema training/schema.sql",
    "etl:ingest-riot": "python -m training.scripts.ingest_from_riot_db",
    "etl:aggregate": "python training/etl/aggregate_effects.py --db training/nexus_training.db --out training/examples/effects",
    "train:champion-dim": "python -m training.scripts.populate_champion_dim --db training/nexus_training.db",
    "train:export": "python -m training.export_effects",
    "train:parity": "python -m training.parity_draft_scorers",
    "draft:init": "python -m draft_v1.build_aggregates --init-schema --seed-sample --rebuild",
    "draft:score": "python -m draft_v1.main",
    "riot:collect": "python -m training.riot_ingest.collect_riot_matches",
    "riot:collect:deep": "python -m training.riot_ingest.collect_riot_matches --max-pages 20",
    "riot:extract": "python -m training.riot_ingest.extract_matches",
    "riot:ladder": "python -m training.riot_ingest.ladder_snowball ladder",
    "riot:snowball": "python -m training.riot_ingest.ladder_snowball snowball"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "electron-store": "^9.0.0",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.38.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^2.1.0",
    "wasm-pack": "^0.15.0"
  },
  "build": {
    "appId": "dev.nexusdraft.app",
    "productName": "Nexus Draft",
    "icon": "favicon.png",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://nexusdraft.lol/downloads/"
      }
    ],
    "files": [
      "out/**/*",
      "!out/renderer/downloads/**/*",
      "package.json",
      "favicon.png"
    ],
    "extraResources": [
      {
        "from": "training/runtime/effects_id.json",
        "to": "training/runtime/effects_id.json"
      }
    ],
    "asar": true,
    "win": {
      "icon": "favicon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "artifactName": "Nexus-Draft-Setup-${version}.exe"
    },
    "portable": {
      "artifactName": "Nexus-Draft-Portable-${version}.exe"
    }
  }
}
