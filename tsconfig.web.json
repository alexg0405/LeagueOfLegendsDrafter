{
  "include": ["src/renderer/src/**/*", "src/shared/**/*.ts", "src/shared/**/*.json"],
  "compilerOptions": {
    "noEmit": true,
    "resolveJsonModule": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@shared": ["src/shared"],
      "@shared/*": ["src/shared/*"]
    }
  }
}
