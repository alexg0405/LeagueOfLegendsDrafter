{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nexus Draft",
  "version": "4.1.0",
  "identifier": "dev.nexusdraft.app",
  "build": {
    "beforeDevCommand": "npm run dev:tauri-renderer",
    "devUrl": "http://127.0.0.1:5174",
    "beforeBuildCommand": "npm run build:tauri-renderer",
    "frontendDist": "../dist/tauri"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Nexus Draft",
        "width": 900,
        "height": 700,
        "resizable": false,
        "maximizable": false,
        "decorations": false,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "publisher": "Nexus Draft contributors",
    "copyright": "Copyright (c) 2026",
    "category": "Utility",
    "shortDescription": "Nexus Draft",
    "longDescription": "Nexus Draft League of Legends draft assistant",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  }
}
